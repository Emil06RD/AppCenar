{{#if success}}
  <div class="alert alert-success alert-dismissible fade show app-alert" role="alert">
    <div class="d-flex align-items-start gap-2">
      <i class="bi bi-check-circle-fill"></i>
      <div>
        <strong>Operacion completada.</strong>
        <div>{{success}}</div>
      </div>
    </div>
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Cerrar"></button>
  </div>
{{/if}}

{{#if error}}
  <div class="alert alert-danger alert-dismissible fade show app-alert" role="alert">
    <div class="d-flex align-items-start gap-2">
      <i class="bi bi-exclamation-triangle-fill"></i>
      <div>
        <strong>Revisa la informacion.</strong>
        <div>{{error}}</div>
      </div>
    </div>
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Cerrar"></button>
  </div>
{{/if}}

{{#if errors.length}}
  <div class="alert alert-danger alert-dismissible fade show app-alert" role="alert">
    <div class="d-flex align-items-start gap-2">
      <i class="bi bi-exclamation-octagon-fill"></i>
      <div>
        <strong>Corrige los siguientes errores:</strong>
        <ul class="mb-0 mt-2 ps-3">
          {{#each errors}}
            <li>{{this}}</li>
          {{/each}}
        </ul>
      </div>
    </div>
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Cerrar"></button>
  </div>
{{/if}}
