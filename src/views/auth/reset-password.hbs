<div class="row justify-content-center">
  <div class="col-12 col-sm-10 col-md-6 col-lg-5">

    <div class="card shadow-sm mt-5">
      <div class="card-body p-4">

        <div class="text-center mb-3">
          <i class="bi bi-shield-lock-fill display-5 text-warning"></i>
        </div>

        <h2 class="card-title text-center mb-1 fw-bold">Nueva contraseña</h2>
        <p class="text-center text-muted mb-4 small">Elige una contraseña segura para tu cuenta.</p>

        {{> alerts}}

        <!-- El token llega en la URL y se pasa como campo oculto -->
        <form action="/auth/reset-password/{{token}}" method="POST" novalidate>

          <input type="hidden" name="token" value="{{token}}" />

          <div class="mb-3">
            <label for="password" class="form-label">Nueva contraseña</label>
            <input
              type="password"
              class="form-control"
              id="password"
              name="password"
              placeholder="Mínimo 6 caracteres"
              required
            />
          </div>

          <div class="mb-4">
            <label for="confirmPassword" class="form-label">Confirmar contraseña</label>
            <input
              type="password"
              class="form-control"
              id="confirmPassword"
              name="confirmPassword"
              placeholder="Repite tu nueva contraseña"
              required
            />
          </div>

          <div class="d-grid">
            <button type="submit" class="btn btn-warning fw-semibold">Restablecer contraseña</button>
          </div>

        </form>

        <hr />

        <p class="text-center small mb-0">
          <a href="/auth/login" class="text-decoration-none">
            <i class="bi bi-arrow-left"></i> Volver al inicio de sesión
          </a>
        </p>

      </div>
    </div>

  </div>
</div>
