<div class="row justify-content-center">
  <div class="col-12 col-sm-10 col-md-7 col-lg-6">

    <div class="card shadow-sm mt-4">
      <div class="card-body p-4">

        <h2 class="card-title text-center mb-1 fw-bold">Crear cuenta</h2>
        <p class="text-center text-muted mb-4 small">Regístrate como cliente o repartidor</p>

        {{> alerts}}

        <form action="/auth/register-user" method="POST" novalidate>

          <!-- Nombre y apellido -->
          <div class="row g-3 mb-3">
            <div class="col-6">
              <label for="firstName" class="form-label">Nombre</label>
              <input
                type="text"
                class="form-control"
                id="firstName"
                name="firstName"
                placeholder="Juan"
                value="{{formData.firstName}}"
                required
              />
            </div>
            <div class="col-6">
              <label for="lastName" class="form-label">Apellido</label>
              <input
                type="text"
                class="form-control"
                id="lastName"
                name="lastName"
                placeholder="Pérez"
                value="{{formData.lastName}}"
                required
              />
            </div>
          </div>

          <!-- Usuario -->
          <div class="mb-3">
            <label for="userName" class="form-label">Nombre de usuario</label>
            <div class="input-group">
              <span class="input-group-text">@</span>
              <input
                type="text"
                class="form-control"
                id="userName"
                name="userName"
                placeholder="juanperez"
                value="{{formData.userName}}"
                required
              />
            </div>
          </div>

          <!-- Email -->
          <div class="mb-3">
            <label for="email" class="form-label">Email</label>
            <input
              type="email"
              class="form-control"
              id="email"
              name="email"
              placeholder="tucorreo@ejemplo.com"
              value="{{formData.email}}"
              required
            />
          </div>

          <!-- Teléfono -->
          <div class="mb-3">
            <label for="phone" class="form-label">Teléfono</label>
            <input
              type="tel"
              class="form-control"
              id="phone"
              name="phone"
              placeholder="+1 809 000 0000"
              value="{{formData.phone}}"
              required
            />
          </div>

          <!-- Contraseña -->
          <div class="mb-3">
            <label for="password" class="form-label">Contraseña</label>
            <input
              type="password"
              class="form-control"
              id="password"
              name="password"
              placeholder="Mínimo 6 caracteres"
              required
            />
          </div>

          <!-- Confirmar contraseña -->
          <div class="mb-3">
            <label for="confirmPassword" class="form-label">Confirmar contraseña</label>
            <input
              type="password"
              class="form-control"
              id="confirmPassword"
              name="confirmPassword"
              placeholder="Repite tu contraseña"
              required
            />
          </div>

          <!-- Rol -->
          <div class="mb-4">
            <label class="form-label">Tipo de cuenta</label>
            <div class="d-flex gap-3">
              <div class="form-check">
                <input
                  class="form-check-input"
                  type="radio"
                  name="role"
                  id="roleClient"
                  value="client"
                  checked
                />
                <label class="form-check-label" for="roleClient">
                  <i class="bi bi-person-fill"></i> Cliente
                </label>
              </div>
              <div class="form-check">
                <input
                  class="form-check-input"
                  type="radio"
                  name="role"
                  id="roleDelivery"
                  value="delivery"
                />
                <label class="form-check-label" for="roleDelivery">
                  <i class="bi bi-bicycle"></i> Repartidor
                </label>
              </div>
            </div>
          </div>

          <div class="d-grid">
            <button type="submit" class="btn btn-warning fw-semibold">Crear cuenta</button>
          </div>

        </form>

        <hr />

        <p class="text-center small mb-0">
          ¿Ya tienes cuenta?
          <a href="/auth/login" class="text-decoration-none fw-semibold">Inicia sesión</a>
        </p>

      </div>
    </div>

  </div>
</div>
