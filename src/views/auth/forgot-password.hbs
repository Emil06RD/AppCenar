<div class="row justify-content-center">
  <div class="col-12 col-sm-10 col-md-6 col-lg-5">
    <div class="card border-0 auth-card mt-4">
      <div class="card-body">
        <div class="text-center mb-3">
          <i class="bi bi-lock-fill display-5 text-warning"></i>
        </div>

        <h2 class="card-title text-center mb-1 fw-bold">Recuperar contrasena</h2>
        <p class="text-center text-muted mb-4 small">
          Ingresa tu email o nombre de usuario y te mostraremos el enlace de recuperacion.
        </p>

        {{> alerts}}

        <form action="/auth/forgot-password" method="POST" novalidate>
          <div class="mb-4">
            <label for="identifier" class="form-label">Email o nombre de usuario</label>
            <input type="text" class="form-control" id="identifier" name="identifier" placeholder="tucorreo@ejemplo.com o @usuario" value="{{formData.identifier}}" required />
          </div>

          <div class="d-grid">
            <button type="submit" class="btn btn-warning fw-semibold">
              <i class="bi bi-send me-1"></i>Enviar enlace
            </button>
          </div>
        </form>

        <hr />

        <p class="text-center small mb-0">
          <a href="/auth/login" class="text-decoration-none">
            <i class="bi bi-arrow-left"></i> Volver al inicio de sesion
          </a>
        </p>
      </div>
    </div>
  </div>
</div>
