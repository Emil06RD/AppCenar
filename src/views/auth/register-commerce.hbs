<div class="row justify-content-center">
  <div class="col-12 col-sm-10 col-md-8 col-lg-7">

    <div class="card shadow-sm mt-4">
      <div class="card-body p-4">

        <h2 class="card-title text-center mb-1 fw-bold">Registrar comercio</h2>
        <p class="text-center text-muted mb-4 small">Crea tu cuenta de dueño y tu comercio en un solo paso</p>

        {{> alerts}}

        <form action="/auth/register-commerce" method="POST" enctype="multipart/form-data" novalidate>

          <!-- ── Datos del dueño ── -->
          <h6 class="text-uppercase text-muted fw-semibold mb-3 small">Datos del dueño</h6>

          <div class="row g-3 mb-3">
            <div class="col-6">
              <label for="firstName" class="form-label">Nombre</label>
              <input
                type="text"
                class="form-control"
                id="firstName"
                name="firstName"
                placeholder="María"
                value="{{data.firstName}}"
                required
              />
            </div>
            <div class="col-6">
              <label for="lastName" class="form-label">Apellido</label>
              <input
                type="text"
                class="form-control"
                id="lastName"
                name="lastName"
                placeholder="González"
                value="{{data.lastName}}"
                required
              />
            </div>
          </div>

          <div class="mb-3">
            <label for="userName" class="form-label">Nombre de usuario</label>
            <div class="input-group">
              <span class="input-group-text">@</span>
              <input
                type="text"
                class="form-control"
                id="userName"
                name="userName"
                placeholder="mariaglez"
                value="{{data.userName}}"
                required
              />
            </div>
          </div>

          <div class="mb-3">
            <label for="email" class="form-label">Email</label>
            <input
              type="email"
              class="form-control"
              id="email"
              name="email"
              placeholder="comercio@ejemplo.com"
              value="{{data.email}}"
              required
            />
          </div>

          <div class="mb-3">
            <label for="phone" class="form-label">Teléfono <span class="text-muted small">(opcional)</span></label>
            <input
              type="tel"
              class="form-control"
              id="phone"
              name="phone"
              placeholder="+1 809 000 0000"
              value="{{data.phone}}"
            />
          </div>

          <div class="mb-3">
            <label for="password" class="form-label">Contraseña</label>
            <input
              type="password"
              class="form-control"
              id="password"
              name="password"
              placeholder="Mínimo 6 caracteres"
              required
            />
          </div>

          <div class="mb-4">
            <label for="confirmPassword" class="form-label">Confirmar contraseña</label>
            <input
              type="password"
              class="form-control"
              id="confirmPassword"
              name="confirmPassword"
              placeholder="Repite tu contraseña"
              required
            />
          </div>

          <hr />

          <!-- ── Datos del comercio ── -->
          <h6 class="text-uppercase text-muted fw-semibold mb-3 small">Datos del comercio</h6>

          <div class="mb-3">
            <label for="commerceName" class="form-label">Nombre del comercio</label>
            <input
              type="text"
              class="form-control"
              id="commerceName"
              name="commerceName"
              placeholder="Pizzería La Bella"
              value="{{data.commerceName}}"
              required
            />
          </div>

          <div class="mb-3">
            <label for="commerceType" class="form-label">Tipo de comercio</label>
            <select class="form-select" id="commerceType" name="commerceType" required>
              <option value="" disabled selected>Selecciona un tipo</option>
              {{#each commerceTypes}}
                <option value="{{this._id}}" {{#if (eq ../data.commerceType this._id)}}selected{{/if}}>
                  {{this.name}}
                </option>
              {{/each}}
            </select>
          </div>

          <div class="row g-3 mb-3">
            <div class="col-6">
              <label for="openingTime" class="form-label">Hora de apertura</label>
              <input
                type="time"
                class="form-control"
                id="openingTime"
                name="openingTime"
                value="{{data.openingTime}}"
                required
              />
            </div>
            <div class="col-6">
              <label for="closingTime" class="form-label">Hora de cierre</label>
              <input
                type="time"
                class="form-control"
                id="closingTime"
                name="closingTime"
                value="{{data.closingTime}}"
                required
              />
            </div>
          </div>

          <div class="mb-4">
            <label for="logo" class="form-label">Logo del comercio <span class="text-muted small">(opcional)</span></label>
            <input
              type="file"
              class="form-control"
              id="logo"
              name="logo"
              accept="image/*"
            />
          </div>

          <div class="d-grid">
            <button type="submit" class="btn btn-warning fw-semibold">Registrar comercio</button>
          </div>

        </form>

        <hr />

        <p class="text-center small mb-0">
          ¿Ya tienes cuenta?
          <a href="/auth/login" class="text-decoration-none fw-semibold">Inicia sesión</a>
        </p>

      </div>
    </div>

  </div>
</div>
