<div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3 mb-4 border-bottom pb-3">
  <div>
    <h1 class="fw-bold mb-0">
      <i class="bi bi-grid text-warning me-2"></i>Mis categorias
    </h1>
    <p class="text-muted mb-0 small">Administra las categorias de tu comercio</p>
  </div>

  <div class="d-flex gap-2">
    <a href="/commerce/home" class="btn btn-outline-secondary btn-sm">
      <i class="bi bi-arrow-left me-1"></i>Volver
    </a>
    <a href="/commerce/categories/create" class="btn btn-warning btn-sm fw-semibold">
      <i class="bi bi-plus-circle me-1"></i>Nueva categoria
    </a>
  </div>
</div>

{{> alerts}}

<div class="card border-0 shadow-sm">
  <div class="card-body">
    {{#if categories.length}}
      <div class="table-responsive">
        <table class="table table-striped table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th>Nombre</th>
              <th>Descripcion</th>
              <th>Productos</th>
              <th class="text-end">Acciones</th>
            </tr>
          </thead>
          <tbody>
            {{#each categories}}
              <tr>
                <td class="fw-semibold">{{this.name}}</td>
                <td>{{this.description}}</td>
                <td>{{this.totalProducts}}</td>
                <td class="text-end">
                  <a href="/commerce/categories/edit/{{this._id}}" class="btn btn-outline-warning btn-sm">
                    <i class="bi bi-pencil-square me-1"></i>Editar
                  </a>
                  <form action="/commerce/categories/delete/{{this._id}}" method="POST" class="d-inline">
                    <button type="submit" class="btn btn-outline-danger btn-sm" onclick="return confirm('¿Eliminar esta categoria?')">
                      <i class="bi bi-trash me-1"></i>Eliminar
                    </button>
                  </form>
                </td>
              </tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    {{else}}
      <div class="empty-state">
        <i class="bi bi-grid"></i>
        <h5 class="fw-semibold">No hay datos disponibles</h5>
        <p class="text-muted mb-3">Crea tu primera categoria para organizar tus productos.</p>
        <a href="/commerce/categories/create" class="btn btn-warning btn-sm fw-semibold">
          <i class="bi bi-plus-circle me-1"></i>Crear categoria
        </a>
      </div>
    {{/if}}
  </div>
</div>
