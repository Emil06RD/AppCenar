<div class="row justify-content-center">
  <div class="col-12 col-md-8 col-lg-6">
    <div class="d-flex align-items-center justify-content-between mb-4 border-bottom pb-3">
      <div>
        <h1 class="fw-bold mb-0">
          <i class="bi bi-plus-circle text-warning me-2"></i>Nueva categoria
        </h1>
        <p class="text-muted mb-0 small">Registra una nueva categoria para tu comercio</p>
      </div>
      <a href="/commerce/categories" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Volver
      </a>
    </div>

    <div class="card border-0 shadow-sm">
      <div class="card-body p-4">
        {{> alerts}}

        <form action="/commerce/categories" method="POST" novalidate>
          <div class="mb-3">
            <label for="name" class="form-label">Nombre de la categoria</label>
            <input
              type="text"
              class="form-control"
              id="name"
              name="name"
              value="{{formData.name}}"
              placeholder="Ej: Hamburguesas"
              required
            />
          </div>

          <div class="mb-3">
            <label for="description" class="form-label">Descripcion</label>
            <textarea
              class="form-control"
              id="description"
              name="description"
              rows="3"
              placeholder="Describe la categoria"
              required
            >{{formData.description}}</textarea>
          </div>

          <div class="d-grid">
            <button type="submit" class="btn btn-warning fw-semibold">Guardar categoria</button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
