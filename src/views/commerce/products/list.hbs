<div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3 mb-4 border-bottom pb-3">
  <div>
    <h1 class="fw-bold mb-0">
      <i class="bi bi-card-list text-warning me-2"></i>Mis productos
    </h1>
    <p class="text-muted mb-0 small">Administra los productos de tu comercio</p>
  </div>

  <div class="d-flex gap-2">
    <a href="/commerce/home" class="btn btn-outline-secondary btn-sm">
      <i class="bi bi-arrow-left me-1"></i>Volver
    </a>
    <a href="/commerce/products/create" class="btn btn-warning btn-sm fw-semibold">
      <i class="bi bi-plus-circle me-1"></i>Nuevo producto
    </a>
  </div>
</div>

{{> alerts}}

<div class="card border-0 shadow-sm">
  <div class="card-body">
    {{#if products.length}}
      <div class="table-responsive">
        <table class="table align-middle mb-0">
          <thead>
            <tr>
              <th>Nombre</th>
              <th>Categoria</th>
              <th>Precio</th>
              <th>Stock</th>
              <th>Estado</th>
              <th class="text-end">Acciones</th>
            </tr>
          </thead>
          <tbody>
            {{#each products}}
              <tr>
                <td class="fw-semibold">{{this.name}}</td>
                <td>{{this.category.name}}</td>
                <td>Bs {{this.price}}</td>
                <td>{{this.stock}}</td>
                <td>
                  {{#if this.isActive}}
                    <span class="badge text-bg-success">Activo</span>
                  {{else}}
                    <span class="badge text-bg-secondary">Inactivo</span>
                  {{/if}}
                </td>
                <td class="text-end">
                  <a href="/commerce/products/edit/{{this._id}}" class="btn btn-outline-warning btn-sm">
                    <i class="bi bi-pencil-square me-1"></i>Editar
                  </a>
                  <form action="/commerce/products/toggle/{{this._id}}" method="POST" class="d-inline">
                    <button type="submit" class="btn btn-outline-dark btn-sm">
                      {{#if this.isActive}}
                        <i class="bi bi-pause-circle me-1"></i>Desactivar
                      {{else}}
                        <i class="bi bi-play-circle me-1"></i>Activar
                      {{/if}}
                    </button>
                  </form>
                </td>
              </tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    {{else}}
      <div class="text-center py-4">
        <i class="bi bi-card-list display-5 text-muted d-block mb-3"></i>
        <h5 class="fw-semibold">Aun no tienes productos</h5>
        <p class="text-muted mb-3">Crea tu primer producto y asignalo a una categoria activa.</p>
        <a href="/commerce/products/create" class="btn btn-warning btn-sm fw-semibold">
          Crear producto
        </a>
      </div>
    {{/if}}
  </div>
</div>
