<div class="row justify-content-center">
  <div class="col-12 col-lg-8">
    <div class="d-flex align-items-center justify-content-between mb-4 border-bottom pb-3">
      <div>
        <h1 class="fw-bold mb-0">
          <i class="bi bi-plus-circle text-warning me-2"></i>Nuevo producto
        </h1>
        <p class="text-muted mb-0 small">Registra un nuevo producto para tu comercio</p>
      </div>
      <a href="/commerce/products" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Volver
      </a>
    </div>

    <div class="card border-0 shadow-sm">
      <div class="card-body p-4">
        {{> alerts}}

        {{#if categories.length}}
          <form action="/commerce/products" method="POST" novalidate>
            <div class="row g-3">
              <div class="col-12 col-md-6">
                <label for="name" class="form-label">Nombre del producto</label>
                <input
                  type="text"
                  class="form-control"
                  id="name"
                  name="name"
                  value="{{formData.name}}"
                  placeholder="Ej: Hamburguesa clasica"
                  required
                />
              </div>

              <div class="col-12 col-md-6">
                <label for="category" class="form-label">Categoria</label>
                <select class="form-select" id="category" name="category" required>
                  <option value="">Selecciona una categoria</option>
                  {{#each categories}}
                    <option value="{{this._id}}" {{#if this.selected}}selected{{/if}}>{{this.name}}</option>
                  {{/each}}
                </select>
              </div>

              <div class="col-12">
                <label for="description" class="form-label">Descripcion</label>
                <textarea
                  class="form-control"
                  id="description"
                  name="description"
                  rows="3"
                  placeholder="Describe el producto"
                >{{formData.description}}</textarea>
              </div>

              <div class="col-12 col-md-6">
                <label for="price" class="form-label">Precio</label>
                <input
                  type="number"
                  class="form-control"
                  id="price"
                  name="price"
                  min="0"
                  step="0.01"
                  value="{{formData.price}}"
                  required
                />
              </div>

              <div class="col-12 col-md-6">
                <label for="stock" class="form-label">Stock</label>
                <input
                  type="number"
                  class="form-control"
                  id="stock"
                  name="stock"
                  min="0"
                  step="1"
                  value="{{formData.stock}}"
                  required
                />
              </div>
            </div>

            <div class="d-grid mt-4">
              <button type="submit" class="btn btn-warning fw-semibold">Guardar producto</button>
            </div>
          </form>
        {{else}}
          <div class="text-center py-4">
            <i class="bi bi-tags display-5 text-muted d-block mb-3"></i>
            <h5 class="fw-semibold">Necesitas una categoria activa</h5>
            <p class="text-muted mb-3">Antes de crear productos, registra al menos una categoria activa.</p>
            <a href="/commerce/categories/create" class="btn btn-warning btn-sm fw-semibold">
              Crear categoria
            </a>
          </div>
        {{/if}}
      </div>
    </div>
  </div>
</div>
