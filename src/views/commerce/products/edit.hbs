<div class="row justify-content-center">
  <div class="col-12 col-lg-8">
    <div class="d-flex align-items-center justify-content-between mb-4 border-bottom pb-3">
      <div>
        <h1 class="fw-bold mb-0">
          <i class="bi bi-pencil-square text-warning me-2"></i>Editar producto
        </h1>
        <p class="text-muted mb-0 small">Actualiza la informacion del producto</p>
      </div>
      <a href="/commerce/products" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Volver
      </a>
    </div>

    <div class="card border-0 shadow-sm">
      <div class="card-body p-4">
        {{> alerts}}

        <form action="/commerce/products/edit/{{product._id}}" method="POST" enctype="multipart/form-data" novalidate>
          <div class="row g-3">
            <div class="col-12 col-md-6">
              <label for="name" class="form-label">Nombre del producto</label>
              <input
                type="text"
                class="form-control"
                id="name"
                name="name"
                value="{{product.name}}"
                placeholder="Ej: Hamburguesa clasica"
                required
              />
            </div>

            <div class="col-12 col-md-6">
              <label for="category" class="form-label">Categoria</label>
              <select class="form-select" id="category" name="category" required>
                <option value="">Selecciona una categoria</option>
                {{#each categories}}
                  <option value="{{this._id}}" {{#if this.selected}}selected{{/if}}>{{this.name}}</option>
                {{/each}}
              </select>
            </div>

            <div class="col-12">
              <label for="description" class="form-label">Descripcion</label>
              <textarea
                class="form-control"
                id="description"
                name="description"
                rows="3"
                placeholder="Describe el producto"
                required
              >{{product.description}}</textarea>
            </div>

            <div class="col-12 col-md-6">
              <label for="price" class="form-label">Precio</label>
              <input
                type="number"
                class="form-control"
                id="price"
                name="price"
                min="0.01"
                step="0.01"
                value="{{product.price}}"
                required
              />
            </div>

            <div class="col-12 col-md-6">
              <label for="image" class="form-label">Nueva imagen</label>
              <input
                type="file"
                class="form-control"
                id="image"
                name="image"
                accept="image/*"
              />
            </div>

            <div class="col-12">
              <label for="isActive" class="form-label">Estado</label>
              <select class="form-select" id="isActive" name="isActive">
                <option value="true" {{#if product.isActive}}selected{{/if}}>Activo</option>
                <option value="false" {{#unless product.isActive}}selected{{/unless}}>Inactivo</option>
              </select>
            </div>
          </div>

          <div class="d-grid mt-4">
            <button type="submit" class="btn btn-warning fw-semibold">Actualizar producto</button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
