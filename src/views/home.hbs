<section
  id="landing-react-root"
  data-title="{{message}}"
  data-cta-href="{{ctaHref}}"
  data-cta-label="{{ctaLabel}}"
  data-is-authenticated="{{#if session.userId}}true{{else}}false{{/if}}"
></section>

<noscript>
  <div class="appcenar-hero-fallback text-center py-5">
    <i class="bi bi-bowl-hot-fill display-1 text-warning"></i>
    <h1 class="mt-3 fw-bold">{{message}}</h1>
    <p class="text-muted fs-5">La plataforma de pedidos de comida a domicilio.</p>
    <a href="{{ctaHref}}" class="btn btn-warning btn-lg mt-3 fw-semibold">
      <i class="bi bi-arrow-right-circle me-1"></i> {{ctaLabel}}
    </a>
  </div>
</noscript>

<script crossorigin src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
<script crossorigin src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
<script src="/js/landing-home.js"></script>
