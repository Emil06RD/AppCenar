<div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3 mb-4 border-bottom pb-3">
  <div>
    <h1 class="fw-bold mb-0"><i class="bi bi-person-plus text-warning me-2"></i>Nuevo administrador</h1>
    <p class="text-muted mb-0 small">Crea una nueva cuenta administrativa.</p>
  </div>
  <a href="/admin/administrators" class="btn btn-outline-secondary btn-sm">
    <i class="bi bi-arrow-left me-1"></i>Volver
  </a>
</div>

{{> alerts}}

<div class="card border-0 shadow-sm">
  <div class="card-body">
    <form action="/admin/administrators/create" method="POST" class="row g-3">
      <div class="col-12 col-md-6"><label class="form-label fw-semibold" for="firstName">Nombre</label><input class="form-control" id="firstName" name="firstName" value="{{admin.firstName}}" required /></div>
      <div class="col-12 col-md-6"><label class="form-label fw-semibold" for="lastName">Apellido</label><input class="form-control" id="lastName" name="lastName" value="{{admin.lastName}}" required /></div>
      <div class="col-12 col-md-6"><label class="form-label fw-semibold" for="userName">Usuario</label><input class="form-control" id="userName" name="userName" value="{{admin.userName}}" required /></div>
      <div class="col-12 col-md-6"><label class="form-label fw-semibold" for="email">Email</label><input type="email" class="form-control" id="email" name="email" value="{{admin.email}}" required /></div>
      <div class="col-12"><label class="form-label fw-semibold" for="phone">Telefono</label><input class="form-control" id="phone" name="phone" value="{{admin.phone}}" required /></div>
      <div class="col-12 col-md-6"><label class="form-label fw-semibold" for="password">Contrasena</label><input type="password" class="form-control" id="password" name="password" required /></div>
      <div class="col-12 col-md-6"><label class="form-label fw-semibold" for="confirmPassword">Confirmar contrasena</label><input type="password" class="form-control" id="confirmPassword" name="confirmPassword" required /></div>
      <div class="col-12"><button type="submit" class="btn btn-warning fw-semibold">Crear administrador</button></div>
    </form>
  </div>
</div>
