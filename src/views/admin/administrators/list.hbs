<div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3 mb-4 border-bottom pb-3">
  <div>
    <h1 class="fw-bold mb-0"><i class="bi bi-person-badge text-warning me-2"></i>Administradores</h1>
    <p class="text-muted mb-0 small">Gestiona las cuentas administrativas del sistema.</p>
  </div>
  <div class="d-flex gap-2">
    <a href="/admin" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i>Volver</a>
    <a href="/admin/administrators/create" class="btn btn-warning btn-sm fw-semibold">Nuevo administrador</a>
  </div>
</div>

{{> alerts}}

<div class="card border-0 shadow-sm">
  <div class="card-body p-0">
    {{#if admins.length}}
      <div class="table-responsive">
        <table class="table align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th>Nombre</th>
              <th>Usuario</th>
              <th>Email</th>
              <th>Estado</th>
              <th class="text-end">Acciones</th>
            </tr>
          </thead>
          <tbody>
            {{#each admins}}
              <tr>
                <td>{{this.firstName}} {{this.lastName}}</td>
                <td>{{this.userName}}</td>
                <td>{{this.email}}</td>
                <td>
                  {{#if this.isActive}}
                    <span class="badge text-bg-success">Activo</span>
                  {{else}}
                    <span class="badge text-bg-secondary">Inactivo</span>
                  {{/if}}
                </td>
                <td class="text-end">
                  <a href="/admin/administrators/{{this._id}}/edit" class="btn btn-outline-warning btn-sm">Editar</a>
                  {{#unless this.isCurrent}}
                    <form action="/admin/administrators/{{this._id}}/delete" method="POST" class="d-inline">
                      <button type="submit" class="btn btn-outline-danger btn-sm">Eliminar</button>
                    </form>
                  {{/unless}}
                </td>
              </tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    {{else}}
      <div class="p-4 text-center">
        <i class="bi bi-person-badge fs-1 text-muted d-block mb-3"></i>
        <h2 class="h5 fw-semibold">No hay administradores registrados</h2>
        <p class="text-muted mb-0">Crea el primero desde este panel.</p>
      </div>
    {{/if}}
  </div>
</div>
