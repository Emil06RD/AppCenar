<div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3 mb-4 border-bottom pb-3">
  <div>
    <h1 class="fw-bold mb-0"><i class="bi bi-person-badge text-warning me-2"></i>Administradores</h1>
    <p class="text-muted mb-0 small">Gestiona las cuentas administrativas del sistema.</p>
  </div>
  <div class="d-flex gap-2">
    <a href="/admin" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i>Volver</a>
    <a href="/admin/administrators/create" class="btn btn-warning btn-sm fw-semibold"><i class="bi bi-plus-circle me-1"></i>Nuevo administrador</a>
  </div>
</div>

{{> alerts}}

<div class="card border-0 shadow-sm">
  <div class="card-body p-0">
    {{#if admins.length}}
      <div class="table-responsive">
        <table class="table table-striped table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th>Nombre</th>
              <th>Usuario</th>
              <th>Email</th>
              <th>Estado</th>
              <th class="text-end">Acciones</th>
            </tr>
          </thead>
          <tbody>
            {{#each admins}}
              <tr>
                <td class="fw-semibold">{{this.firstName}} {{this.lastName}}</td>
                <td>{{this.userName}}</td>
                <td>{{this.email}}</td>
                <td>
                  {{#if this.isActive}}
                    <span class="badge text-bg-success">Activo</span>
                  {{else}}
                    <span class="badge text-bg-secondary">Inactivo</span>
                  {{/if}}
                </td>
                <td class="text-end">
                  <a href="/admin/administrators/{{this._id}}/edit" class="btn btn-outline-warning btn-sm">
                    <i class="bi bi-pencil-square me-1"></i>Editar
                  </a>
                  {{#unless this.isCurrent}}
                    <form action="/admin/users/{{this._id}}/toggle" method="POST" class="d-inline">
                      <input type="hidden" name="currentStatus" value="{{#if this.isActive}}true{{else}}false{{/if}}" />
                      <button type="submit" class="btn btn-outline-dark btn-sm">
                        {{#if this.isActive}}
                          <i class="bi bi-pause-circle me-1"></i>Desactivar
                        {{else}}
                          <i class="bi bi-play-circle me-1"></i>Activar
                        {{/if}}
                      </button>
                    </form>
                  {{/unless}}
                </td>
              </tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    {{else}}
      <div class="empty-state">
        <i class="bi bi-person-badge"></i>
        <h2 class="h5 fw-semibold">No hay datos disponibles</h2>
        <p class="text-muted mb-0">Crea el primer administrador desde este panel.</p>
      </div>
    {{/if}}
  </div>
</div>
