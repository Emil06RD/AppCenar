<div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3 mb-4 border-bottom pb-3">
  <div>
    <h1 class="fw-bold mb-0">
      <i class="bi bi-people text-warning me-2"></i>Usuarios
    </h1>
    <p class="text-muted mb-0 small">Administra el estado de los usuarios disponibles en la API.</p>
  </div>
  <a href="/admin" class="btn btn-outline-secondary btn-sm">
    <i class="bi bi-arrow-left me-1"></i>Volver
  </a>
</div>

{{> alerts}}

<div class="card border-0 shadow-sm mb-4">
  <div class="card-body">
    <form action="/admin/users" method="GET" class="row g-3 align-items-end">
      <div class="col-12 col-md-4">
        <label for="role" class="form-label fw-semibold">Filtrar por rol</label>
        <select id="role" name="role" class="form-select">
          <option value="">Todos</option>
          <option value="client" {{#if roleFilters.client}}selected{{/if}}>Cliente</option>
          <option value="commerce" {{#if roleFilters.commerce}}selected{{/if}}>Comercio</option>
          <option value="delivery" {{#if roleFilters.delivery}}selected{{/if}}>Delivery</option>
          <option value="admin" {{#if roleFilters.admin}}selected{{/if}}>Admin</option>
        </select>
      </div>
      <div class="col-12 col-md-4">
        <label for="search" class="form-label fw-semibold">Buscar</label>
        <input type="text" id="search" name="search" class="form-control" value="{{search}}" placeholder="Nombre, usuario o email" />
      </div>
      <div class="col-12 col-md-2">
        <label for="isActive" class="form-label fw-semibold">Estado</label>
        <select id="isActive" name="isActive" class="form-select">
          <option value="">Todos</option>
          <option value="true" {{#if statusFilters.active}}selected{{/if}}>Activo</option>
          <option value="false" {{#if statusFilters.inactive}}selected{{/if}}>Inactivo</option>
        </select>
      </div>
      <div class="col-12 col-md-2 d-grid">
        <button type="submit" class="btn btn-warning fw-semibold">
          <i class="bi bi-funnel me-1"></i>Filtrar
        </button>
      </div>
    </form>
  </div>
</div>

<div class="card border-0 shadow-sm">
  <div class="card-body p-0">
    {{#if users.length}}
      <div class="table-responsive">
        <table class="table table-striped table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th>Nombre</th>
              <th>Usuario</th>
              <th>Rol</th>
              <th>Estado</th>
              <th class="text-end">Acciones</th>
            </tr>
          </thead>
          <tbody>
            {{#each users}}
              <tr>
                <td class="fw-semibold">{{this.firstName}} {{this.lastName}}</td>
                <td>{{this.userName}}</td>
                <td><span class="app-pill">{{this.roleLabel}}</span></td>
                <td>
                  {{#if this.isActive}}
                    <span class="badge text-bg-success">Activo</span>
                  {{else}}
                    <span class="badge text-bg-secondary">Inactivo</span>
                  {{/if}}
                </td>
                <td class="text-end">
                  <form action="/admin/users/{{this._id}}/toggle" method="POST" class="d-inline">
                    <input type="hidden" name="currentStatus" value="{{#if this.isActive}}true{{else}}false{{/if}}" />
                    <button type="submit" class="btn btn-outline-dark btn-sm">
                      {{#if this.isActive}}
                        <i class="bi bi-pause-circle me-1"></i>Desactivar
                      {{else}}
                        <i class="bi bi-play-circle me-1"></i>Activar
                      {{/if}}
                    </button>
                  </form>
                </td>
              </tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    {{else}}
      <div class="empty-state">
        <i class="bi bi-people"></i>
        <h2 class="h5 fw-semibold">No hay datos disponibles</h2>
        <p class="text-muted mb-0">Prueba con otro filtro para encontrar usuarios.</p>
      </div>
    {{/if}}
  </div>
</div>
