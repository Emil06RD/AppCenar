<div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3 mb-4 border-bottom pb-3">
  <div>
    <h1 class="fw-bold mb-0">
      <i class="bi bi-people text-warning me-2"></i>Usuarios
    </h1>
    <p class="text-muted mb-0 small">Administra el estado de los usuarios y la aprobacion de comercios.</p>
  </div>
  <a href="/admin" class="btn btn-outline-secondary btn-sm">
    <i class="bi bi-arrow-left me-1"></i>Volver
  </a>
</div>

{{> alerts}}

<div class="card border-0 shadow-sm mb-4">
  <div class="card-body">
    <form action="/admin/users" method="GET" class="row g-3 align-items-end">
      <div class="col-12 col-md-4">
        <label for="role" class="form-label fw-semibold">Filtrar por rol</label>
        <select id="role" name="role" class="form-select">
          <option value="">Todos</option>
          <option value="client" {{#if roleFilters.client}}selected{{/if}}>Cliente</option>
          <option value="commerce" {{#if roleFilters.commerce}}selected{{/if}}>Comercio</option>
          <option value="delivery" {{#if roleFilters.delivery}}selected{{/if}}>Delivery</option>
          <option value="admin" {{#if roleFilters.admin}}selected{{/if}}>Admin</option>
        </select>
      </div>
      <div class="col-12 col-md-2 d-grid">
        <button type="submit" class="btn btn-warning fw-semibold">Filtrar</button>
      </div>
    </form>
  </div>
</div>

<div class="card border-0 shadow-sm">
  <div class="card-body p-0">
    {{#if users.length}}
      <div class="table-responsive">
        <table class="table align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th>Nombre</th>
              <th>Usuario</th>
              <th>Rol</th>
              <th>Estado</th>
              <th class="text-end">Acciones</th>
            </tr>
          </thead>
          <tbody>
            {{#each users}}
              <tr>
                <td>{{this.firstName}} {{this.lastName}}</td>
                <td>{{this.userName}}</td>
                <td>{{this.role}}</td>
                <td>
                  {{#if this.isActive}}
                    <span class="badge text-bg-success">Activo</span>
                  {{else}}
                    <span class="badge text-bg-secondary">Inactivo</span>
                  {{/if}}
                  {{#if this.isApproved}}
                    <span class="badge text-bg-warning">Aprobado</span>
                  {{/if}}
                </td>
                <td class="text-end">
                  <form action="/admin/users/{{this._id}}/toggle" method="POST" class="d-inline">
                    <button type="submit" class="btn btn-outline-dark btn-sm">
                      {{#if this.isActive}}Desactivar{{else}}Activar{{/if}}
                    </button>
                  </form>
                  {{#if this.isCommerce}}
                    <form action="/admin/users/{{this._id}}/approve" method="POST" class="d-inline">
                      <button type="submit" class="btn btn-outline-warning btn-sm">
                        {{#if this.isApproved}}Rechazar{{else}}Aprobar{{/if}}
                      </button>
                    </form>
                  {{/if}}
                </td>
              </tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    {{else}}
      <div class="p-4 text-center">
        <i class="bi bi-people fs-1 text-muted d-block mb-3"></i>
        <h2 class="h5 fw-semibold">No hay usuarios para mostrar</h2>
        <p class="text-muted mb-0">Prueba con otro filtro.</p>
      </div>
    {{/if}}
  </div>
</div>
