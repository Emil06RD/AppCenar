<div class="d-flex align-items-center justify-content-between mb-4">
  <div>
    <h1 class="fw-bold mb-1">Editar tipo de comercio</h1>
    <p class="text-muted mb-0">Actualiza la informacion del tipo seleccionado.</p>
  </div>
  <a href="/admin/commerce-types" class="btn btn-outline-secondary">Volver</a>
</div>

{{> alerts}}

<div class="card border-0 shadow-sm">
  <div class="card-body">
    <form action="/admin/commerce-types/{{commerceType._id}}/edit" method="POST" enctype="multipart/form-data" class="row g-3">
      <div class="col-12">
        <label for="name" class="form-label fw-semibold">Nombre</label>
        <input
          type="text"
          id="name"
          name="name"
          class="form-control"
          value="{{commerceType.name}}"
          required
        />
      </div>

      <div class="col-12">
        <label for="description" class="form-label fw-semibold">Descripcion</label>
        <textarea
          id="description"
          name="description"
          class="form-control"
          rows="4"
        >{{commerceType.description}}</textarea>
      </div>

      <div class="col-12">
        <label for="icon" class="form-label fw-semibold">Nuevo icono</label>
        <input type="file" id="icon" name="icon" class="form-control" accept="image/*" />
      </div>

      <div class="col-12">
        <label for="isActive" class="form-label fw-semibold">Estado</label>
        <select id="isActive" name="isActive" class="form-select">
          <option value="true" {{#if commerceType.isActive}}selected{{/if}}>Activo</option>
          <option value="false" {{#unless commerceType.isActive}}selected{{/unless}}>Inactivo</option>
        </select>
      </div>

      <div class="col-12 d-flex gap-2">
        <button type="submit" class="btn btn-warning fw-semibold">Guardar cambios</button>
        <a href="/admin/commerce-types" class="btn btn-outline-secondary">Cancelar</a>
      </div>
    </form>
  </div>
</div>
