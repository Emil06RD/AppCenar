<div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3 mb-4">
  <div>
    <h1 class="fw-bold mb-1">Tipos de comercio</h1>
    <p class="text-muted mb-0">Administra los tipos de comercio disponibles en la plataforma.</p>
  </div>
  <a href="/admin/commerce-types/create" class="btn btn-warning fw-semibold">
    <i class="bi bi-plus-circle me-1"></i>Nuevo tipo
  </a>
</div>

{{> alerts}}

<div class="card border-0 shadow-sm">
  <div class="card-body p-0">
    {{#if commerceTypes.length}}
      <div class="table-responsive">
        <table class="table align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th>Nombre</th>
              <th>Descripcion</th>
              <th>Estado</th>
              <th>Icono</th>
              <th class="text-end">Acciones</th>
            </tr>
          </thead>
          <tbody>
            {{#each commerceTypes}}
              <tr>
                <td class="fw-semibold">{{this.name}}</td>
                <td>{{#if this.description}}{{this.description}}{{else}}<span class="text-muted">Sin descripcion</span>{{/if}}</td>
                <td>
                  {{#if this.isActive}}
                    <span class="badge text-bg-success">Activo</span>
                  {{else}}
                    <span class="badge text-bg-secondary">Inactivo</span>
                  {{/if}}
                </td>
                <td>{{#if this.icon}}Cargado{{else}}Sin icono{{/if}}</td>
                <td class="text-end">
                  <a href="/admin/commerce-types/{{this._id}}/edit" class="btn btn-outline-warning btn-sm">
                    Editar
                  </a>
                  <form action="/admin/commerce-types/{{this._id}}/delete" method="POST" class="d-inline">
                    <button type="submit" class="btn btn-outline-danger btn-sm" onclick="return confirm('¿Eliminar este tipo de comercio?')">
                      Eliminar
                    </button>
                  </form>
                </td>
              </tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    {{else}}
      <div class="p-4 text-center">
        <i class="bi bi-tags fs-1 text-warning d-block mb-3"></i>
        <h2 class="h5 fw-semibold">Todavia no hay tipos de comercio</h2>
        <p class="text-muted mb-3">Crea el primero para empezar a organizar los comercios.</p>
        <a href="/admin/commerce-types/create" class="btn btn-warning">Crear tipo de comercio</a>
      </div>
    {{/if}}
  </div>
</div>
