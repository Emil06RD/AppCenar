<div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3 mb-4 border-bottom pb-3">
  <div>
    <h1 class="fw-bold mb-0">
      <i class="bi bi-gear text-warning me-2"></i>Configuracion
    </h1>
    <p class="text-muted mb-0 small">Administra los parametros globales del sistema.</p>
  </div>
  <a href="/admin" class="btn btn-outline-secondary btn-sm">
    <i class="bi bi-arrow-left me-1"></i>Volver
  </a>
</div>

{{> alerts}}

<div class="row justify-content-center">
  <div class="col-12 col-md-8 col-lg-6">
    <div class="card border-0 shadow-sm">
      <div class="card-body">
        <form action="/admin/configuration" method="POST" class="row g-3">
          <div class="col-12">
            <label for="itbis" class="form-label fw-semibold">ITBIS (%)</label>
            <input
              type="number"
              id="itbis"
              name="itbis"
              class="form-control"
              min="0"
              max="100"
              step="0.01"
              value="{{config.itbis}}"
              required
            />
          </div>

          <div class="col-12 d-grid">
            <button type="submit" class="btn btn-warning fw-semibold">Guardar configuracion</button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
