<div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3 mb-4 border-bottom pb-3">
  <div>
    <h1 class="fw-bold mb-0">
      <i class="bi bi-person-circle text-warning me-2"></i>Hola, {{session.userName}}
    </h1>
    <p class="text-muted mb-0 small">Explora comercios por tipo y encuentra lo que te apetece hoy.</p>
  </div>
  <a href="/auth/logout" class="btn btn-outline-danger btn-sm">
    <i class="bi bi-box-arrow-right me-1"></i>Cerrar sesion
  </a>
</div>

{{> alerts}}

<div class="card border-0 shadow-sm mb-4">
  <div class="card-body">
    <form action="/client/commerces" method="GET" class="row g-2 align-items-end">
      <div class="col-12 col-md-9">
        <label for="search" class="form-label fw-semibold">Buscar comercios por nombre</label>
        <input
          type="text"
          id="search"
          name="search"
          class="form-control"
          placeholder="Ej: Burger House"
        />
      </div>
      <div class="col-12 col-md-3 d-grid">
        <button type="submit" class="btn btn-warning fw-semibold">Buscar</button>
      </div>
    </form>
  </div>
</div>

<div class="d-flex align-items-center justify-content-between mb-3">
  <h2 class="h4 fw-bold mb-0">Tipos de comercio activos</h2>
  <div class="d-flex gap-2">
    <a href="/client/favorites" class="btn btn-outline-warning btn-sm">Mis favoritos</a>
    <a href="/client/commerces" class="btn btn-outline-secondary btn-sm">Ver todos</a>
  </div>
</div>

<div class="row g-4">
  {{#if commerceTypes.length}}
    {{#each commerceTypes}}
      <div class="col-12 col-md-6 col-lg-4">
        <div class="card h-100 border-0 shadow-sm">
          <div class="card-body d-flex flex-column">
            <div class="mb-3">
              <span class="badge text-bg-warning">{{this.name}}</span>
            </div>
            <h3 class="h5 fw-semibold">{{this.name}}</h3>
            <p class="text-muted flex-grow-1 mb-3">
              {{#if this.description}}
                {{this.description}}
              {{else}}
                Explora los comercios disponibles dentro de esta categoria.
              {{/if}}
            </p>
            <a href="/client/commerces?type={{this._id}}" class="btn btn-warning fw-semibold">
              Ver comercios
            </a>
          </div>
        </div>
      </div>
    {{/each}}
  {{else}}
    <div class="col-12">
      <div class="card border-0 shadow-sm">
        <div class="card-body text-center py-5">
          <i class="bi bi-shop-window display-5 text-muted d-block mb-3"></i>
          <h2 class="h5 fw-semibold">No hay tipos de comercio disponibles</h2>
          <p class="text-muted mb-0">Cuando existan tipos activos, apareceran aqui.</p>
        </div>
      </div>
    </div>
  {{/if}}
</div>
