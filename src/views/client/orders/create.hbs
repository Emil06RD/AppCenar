<div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3 mb-4 border-bottom pb-3">
  <div>
    <h1 class="fw-bold mb-0">
      <i class="bi bi-bag-plus text-warning me-2"></i>Nuevo pedido
    </h1>
    <p class="text-muted mb-0 small">{{commerce.name}} · Selecciona productos y una direccion de entrega.</p>
  </div>
  <a href="/client/commerces/{{commerce._id}}/products" class="btn btn-outline-secondary btn-sm">
    <i class="bi bi-arrow-left me-1"></i>Volver al catalogo
  </a>
</div>

{{> alerts}}

{{#if addresses.length}}
  {{#if products.length}}
    <form action="/client/orders" method="POST">
      <input type="hidden" name="commerceId" value="{{commerce._id}}" />

      <div class="row g-4">
        <div class="col-12 col-lg-8">
          <div class="card border-0 shadow-sm">
            <div class="card-body">
              <h2 class="h5 fw-semibold mb-3">Productos</h2>

              <div class="d-flex flex-column gap-3">
                {{#each products}}
                  <div class="border rounded-3 p-3">
                    <div class="d-flex flex-column flex-md-row justify-content-between gap-3">
                      <div>
                        <div class="d-flex align-items-center gap-2 mb-1">
                          <h3 class="h6 fw-semibold mb-0">{{this.name}}</h3>
                          <span class="badge text-bg-light">{{this.category.name}}</span>
                        </div>
                        <p class="text-muted small mb-2">
                          {{#if this.description}}
                            {{this.description}}
                          {{else}}
                            Sin descripcion disponible.
                          {{/if}}
                        </p>
                        <div class="small text-muted">Stock disponible: {{this.stock}}</div>
                      </div>

                      <div class="d-flex flex-column align-items-md-end gap-2">
                        <div class="fw-bold text-warning">RD$ {{this.price}}</div>
                        <label class="small text-muted" for="qty-{{this._id}}">Cantidad</label>
                        <input
                          type="number"
                          id="qty-{{this._id}}"
                          name="quantities[{{this._id}}]"
                          min="0"
                          max="{{this.stock}}"
                          value="0"
                          class="form-control"
                          style="width: 96px;"
                        />
                      </div>
                    </div>
                  </div>
                {{/each}}
              </div>
            </div>
          </div>
        </div>

        <div class="col-12 col-lg-4">
          <div class="card border-0 shadow-sm mb-4">
            <div class="card-body">
              <h2 class="h5 fw-semibold mb-3">Direccion de entrega</h2>

              <div class="d-flex flex-column gap-3">
                {{#each addresses}}
                  <label class="border rounded-3 p-3">
                    <div class="form-check">
                      <input
                        class="form-check-input"
                        type="radio"
                        name="addressId"
                        value="{{this._id}}"
                        {{#if this.isDefault}}checked{{/if}}
                        required
                      />
                      <span class="form-check-label">
                        <span class="fw-semibold d-block">{{this.street}}</span>
                        <span class="text-muted d-block">{{this.city}}</span>
                        {{#if this.reference}}
                          <span class="small text-muted d-block">Referencia: {{this.reference}}</span>
                        {{/if}}
                      </span>
                    </div>
                  </label>
                {{/each}}
              </div>
            </div>
          </div>

          <div class="card border-0 shadow-sm">
            <div class="card-body">
              <h2 class="h5 fw-semibold mb-3">Resumen</h2>
              <p class="text-muted small mb-2">El pedido debe contener al menos un producto.</p>
              <p class="text-muted small mb-2">Todos los productos pertenecen a un solo comercio.</p>
              <p class="text-muted small mb-3">ITBIS aplicado: {{itbisPercent}}%</p>

              <div class="d-grid">
                <button type="submit" class="btn btn-warning fw-semibold">Confirmar pedido</button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </form>
  {{else}}
    <div class="card border-0 shadow-sm">
      <div class="card-body text-center py-5">
        <i class="bi bi-basket display-5 text-muted d-block mb-3"></i>
        <h2 class="h5 fw-semibold">No hay productos disponibles</h2>
        <p class="text-muted mb-0">Este comercio no tiene productos con stock por ahora.</p>
      </div>
    </div>
  {{/if}}
{{else}}
  <div class="card border-0 shadow-sm">
    <div class="card-body text-center py-5">
      <i class="bi bi-geo-alt display-5 text-muted d-block mb-3"></i>
      <h2 class="h5 fw-semibold">Necesitas una direccion</h2>
      <p class="text-muted mb-3">Selecciona o crea una direccion antes de hacer tu pedido.</p>
      <a href="/client/addresses/create" class="btn btn-warning">Crear direccion</a>
    </div>
  </div>
{{/if}}
