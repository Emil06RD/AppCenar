<div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3 mb-4 border-bottom pb-3">
  <div>
    <h1 class="fw-bold mb-0">
      <i class="bi bi-receipt text-warning me-2"></i>Mis pedidos
    </h1>
    <p class="text-muted mb-0 small">Historial de pedidos realizados.</p>
  </div>
  <a href="/client/home" class="btn btn-outline-secondary btn-sm">
    <i class="bi bi-arrow-left me-1"></i>Volver
  </a>
</div>

{{> alerts}}

<div class="d-flex flex-column gap-3">
  {{#if orders.length}}
    {{#each orders}}
      <div class="card border-0 shadow-sm">
        <div class="card-body">
          <div class="d-flex flex-column flex-md-row justify-content-between gap-3 mb-3">
            <div>
              <h2 class="h5 fw-semibold mb-1">Pedido #{{this._id}}</h2>
              <div class="text-muted small">{{this.statusLabel}}</div>
            </div>
            <div class="text-md-end">
              <div class="fw-semibold">Total: RD$ {{this.total}}</div>
              <div class="text-muted small">Subtotal: RD$ {{this.subtotal}} · ITBIS: RD$ {{this.itbis}}</div>
            </div>
          </div>

          <div class="small text-muted mb-3">
            {{#if this.address}}
              Entrega en: {{this.address.street}}, {{this.address.city}}
            {{else}}
              Direccion no disponible
            {{/if}}
          </div>

          <ul class="list-group list-group-flush">
            {{#each this.products}}
              <li class="list-group-item px-0 d-flex justify-content-between">
                <span>{{this.product.name}} x{{this.quantity}}</span>
                <span>RD$ {{this.unitPrice}}</span>
              </li>
            {{/each}}
          </ul>

          <div class="mt-3">
            <a href="/client/orders/{{this._id}}" class="btn btn-outline-warning btn-sm">Ver detalle</a>
          </div>
        </div>
      </div>
    {{/each}}
  {{else}}
    <div class="card border-0 shadow-sm">
      <div class="card-body text-center py-5">
        <i class="bi bi-receipt display-5 text-muted d-block mb-3"></i>
        <h2 class="h5 fw-semibold">Aun no tienes pedidos</h2>
        <p class="text-muted mb-0">Cuando hagas tu primer pedido aparecera aqui.</p>
      </div>
    </div>
  {{/if}}
</div>
