<div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3 mb-4 border-bottom pb-3">
  <div>
    <h1 class="fw-bold mb-0">
      <i class="bi bi-basket text-warning me-2"></i>{{commerce.name}}
    </h1>
    <p class="text-muted mb-0 small">
      {{commerce.commerceType.name}} · Horario {{commerce.openingTime}} - {{commerce.closingTime}}
    </p>
  </div>
  <div class="d-flex gap-2">
    <a href="/client/orders/create?commerce={{commerce.user._id}}" class="btn btn-warning btn-sm fw-semibold">
      <i class="bi bi-bag-plus me-1"></i>Hacer pedido
    </a>
    <a href="/client/commerces" class="btn btn-outline-secondary btn-sm">
      <i class="bi bi-arrow-left me-1"></i>Volver
    </a>
  </div>
</div>

{{> alerts}}

<div class="card border-0 shadow-sm mb-4">
  <div class="card-body">
    <form action="/client/commerces/{{commerce.user._id}}/products" method="GET" class="row g-3 align-items-end">
      <div class="col-12 col-md-9">
        <label for="category" class="form-label fw-semibold">Filtrar por categoria</label>
        <select id="category" name="category" class="form-select">
          <option value="">Todas las categorias</option>
          {{#each categories}}
            <option value="{{this._id}}" {{#if this.selected}}selected{{/if}}>{{this.name}}</option>
          {{/each}}
        </select>
      </div>
      <div class="col-12 col-md-3 d-grid">
        <button type="submit" class="btn btn-warning fw-semibold">Filtrar</button>
      </div>
    </form>
  </div>
</div>

{{#if groupedProducts.length}}
  <div class="d-flex flex-column gap-4">
    {{#each groupedProducts}}
      <section class="card border-0 shadow-sm">
        <div class="card-body">
          <div class="d-flex align-items-center justify-content-between mb-3">
            <h2 class="h4 fw-bold mb-0">{{this.name}}</h2>
            <span class="badge text-bg-warning">{{this.products.length}} productos</span>
          </div>

          <div class="row g-3">
            {{#each this.products}}
              <div class="col-12 col-md-6">
                <div class="border rounded-3 p-3 h-100">
                  <div class="d-flex justify-content-between align-items-start gap-3 mb-2">
                    <h3 class="h5 fw-semibold mb-0">{{this.name}}</h3>
                    <span class="fw-bold text-warning">Bs {{this.price}}</span>
                  </div>
                  <p class="text-muted small mb-3">
                    {{#if this.description}}
                      {{this.description}}
                    {{else}}
                      Sin descripcion disponible.
                    {{/if}}
                  </p>
                  <div class="small text-muted">Stock disponible: {{this.stock}}</div>
                </div>
              </div>
            {{/each}}
          </div>
        </div>
      </section>
    {{/each}}
  </div>
{{else}}
  <div class="card border-0 shadow-sm">
    <div class="card-body text-center py-5">
      <i class="bi bi-basket display-5 text-muted d-block mb-3"></i>
      <h2 class="h5 fw-semibold">No hay productos disponibles</h2>
      <p class="text-muted mb-0">Prueba con otra categoria o vuelve mas tarde.</p>
    </div>
  </div>
{{/if}}
