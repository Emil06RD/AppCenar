<div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3 mb-4 border-bottom pb-3">
  <div>
    <h1 class="fw-bold mb-0">
      <i class="bi bi-heart-fill text-danger me-2"></i>Mis favoritos
    </h1>
    <p class="text-muted mb-0 small">Tus comercios guardados para volver rapido cuando quieras.</p>
  </div>
  <a href="/client/home" class="btn btn-outline-secondary btn-sm">
    <i class="bi bi-arrow-left me-1"></i>Volver
  </a>
</div>

{{> alerts}}

<div class="row g-4">
  {{#if commerces.length}}
    {{#each commerces}}
      <div class="col-12 col-md-6 col-lg-4">
        <div class="card h-100 border-0 shadow-sm">
          <div class="card-body d-flex flex-column">
            <div class="d-flex justify-content-between align-items-start mb-3">
              <span class="badge text-bg-warning">{{this.commerceType.name}}</span>
              <i class="bi bi-heart-fill text-danger"></i>
            </div>
            <h2 class="h5 fw-semibold mb-1">{{this.name}}</h2>
            <p class="text-muted small mb-2">Propietario: {{this.ownerName}}</p>
            <p class="text-muted small mb-3">Horario: {{this.openingTime}} - {{this.closingTime}}</p>
            <div class="d-flex gap-2 mt-auto">
              <a href="/client/commerces/{{this._id}}/products" class="btn btn-outline-warning flex-grow-1">
                Ver productos
              </a>
              <form action="/client/favorites/remove" method="POST">
                <input type="hidden" name="commerceId" value="{{this._id}}" />
                <button type="submit" class="btn btn-outline-danger">Quitar</button>
              </form>
            </div>
          </div>
        </div>
      </div>
    {{/each}}
  {{else}}
    <div class="col-12">
      <div class="card border-0 shadow-sm">
        <div class="card-body text-center py-5">
          <i class="bi bi-heart display-5 text-muted d-block mb-3"></i>
          <h2 class="h5 fw-semibold">Aun no tienes favoritos</h2>
          <p class="text-muted mb-3">Explora comercios y guarda los que mas te gusten.</p>
          <a href="/client/commerces" class="btn btn-warning">Explorar comercios</a>
        </div>
      </div>
    </div>
  {{/if}}
</div>
