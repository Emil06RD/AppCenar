<div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3 mb-4 border-bottom pb-3">
  <div>
    <h1 class="fw-bold mb-0">
      <i class="bi bi-shop text-warning me-2"></i>Comercios
    </h1>
    <p class="text-muted mb-0 small">Filtra por tipo o busca por nombre de comercio.</p>
  </div>
  <a href="/client/home" class="btn btn-outline-secondary btn-sm">
    <i class="bi bi-arrow-left me-1"></i>Volver
  </a>
</div>

{{> alerts}}

<div class="card border-0 shadow-sm mb-4">
  <div class="card-body">
    <form action="/client/commerces" method="GET" class="row g-3 align-items-end">
      <div class="col-12 col-md-4">
        <label for="type" class="form-label fw-semibold">Tipo de comercio</label>
        <select id="type" name="type" class="form-select">
          <option value="">Todos</option>
          {{#each commerceTypes}}
            <option value="{{this._id}}" {{#if this.selected}}selected{{/if}}>{{this.name}}</option>
          {{/each}}
        </select>
      </div>
      <div class="col-12 col-md-5">
        <label for="search" class="form-label fw-semibold">Nombre del comercio</label>
        <input
          type="text"
          id="search"
          name="search"
          class="form-control"
          value="{{search}}"
          placeholder="Ej: Burger House"
        />
      </div>
      <div class="col-12 col-md-3 d-grid">
        <button type="submit" class="btn btn-warning fw-semibold">
          <i class="bi bi-search me-1"></i>Buscar
        </button>
      </div>
    </form>
  </div>
</div>

<div class="row g-4">
  {{#if commerces.length}}
    {{#each commerces}}
      <div class="col-12 col-md-6 col-lg-4">
        <div class="card h-100 border-0 shadow-sm">
          <div class="card-body d-flex flex-column">
            <div class="d-flex justify-content-between align-items-start mb-3">
              <span class="badge text-bg-warning">{{this.commerceType.name}}</span>
              {{#if this.isFavorite}}
                <i class="bi bi-heart-fill text-danger"></i>
              {{/if}}
            </div>
            <h2 class="h5 fw-semibold mb-1">{{this.name}}</h2>
            <p class="text-muted small mb-2">Propietario: {{this.ownerName}}</p>
            <p class="text-muted small mb-3">Horario: {{this.openingTime}} - {{this.closingTime}}</p>
            <div class="d-flex gap-2 mt-auto">
              <a href="/client/commerces/{{this._id}}/products" class="btn btn-outline-warning flex-grow-1">
                <i class="bi bi-basket me-1"></i>Ver productos
              </a>
              {{#if this.isFavorite}}
                <form action="/client/favorites/remove" method="POST">
                  <input type="hidden" name="commerceId" value="{{this._id}}" />
                  <button type="submit" class="btn btn-outline-danger">
                    <i class="bi bi-heartbreak"></i>
                  </button>
                </form>
              {{else}}
                <form action="/client/favorites" method="POST">
                  <input type="hidden" name="commerceId" value="{{this._id}}" />
                  <button type="submit" class="btn btn-warning">
                    <i class="bi bi-heart"></i>
                  </button>
                </form>
              {{/if}}
            </div>
          </div>
        </div>
      </div>
    {{/each}}
  {{else}}
    <div class="col-12">
      <div class="card border-0 shadow-sm">
        <div class="empty-state">
          <i class="bi bi-search"></i>
          <h2 class="h5 fw-semibold">No hay datos disponibles</h2>
          <p class="text-muted mb-0">Prueba con otro nombre o cambia el tipo seleccionado.</p>
        </div>
      </div>
    </div>
  {{/if}}
</div>
