<div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3 mb-4 border-bottom pb-3">
  <div>
    <h1 class="fw-bold mb-0"><i class="bi bi-person-circle text-warning me-2"></i>Mi perfil</h1>
    <p class="text-muted mb-0 small">Actualiza tus datos personales como repartidor.</p>
  </div>
  <a href="/delivery/home" class="btn btn-outline-secondary btn-sm">
    <i class="bi bi-arrow-left me-1"></i>Volver
  </a>
</div>

{{> alerts}}

<div class="card border-0 shadow-sm">
  <div class="card-body">
    <form action="/delivery/profile" method="POST" class="row g-3">
      <div class="col-12 col-md-6">
        <label class="form-label fw-semibold" for="firstName">Nombre</label>
        <input class="form-control" id="firstName" name="firstName" value="{{profile.firstName}}" required />
      </div>
      <div class="col-12 col-md-6">
        <label class="form-label fw-semibold" for="lastName">Apellido</label>
        <input class="form-control" id="lastName" name="lastName" value="{{profile.lastName}}" required />
      </div>
      <div class="col-12 col-md-6">
        <label class="form-label fw-semibold" for="userName">Usuario</label>
        <input class="form-control" id="userName" name="userName" value="{{profile.userName}}" required />
      </div>
      <div class="col-12 col-md-6">
        <label class="form-label fw-semibold" for="email">Email</label>
        <input type="email" class="form-control" id="email" name="email" value="{{profile.email}}" required />
      </div>
      <div class="col-12">
        <label class="form-label fw-semibold" for="phone">Telefono</label>
        <input class="form-control" id="phone" name="phone" value="{{profile.phone}}" required />
      </div>
      <div class="col-12">
        <button type="submit" class="btn btn-warning fw-semibold">Guardar cambios</button>
      </div>
    </form>
  </div>
</div>
