{{! ── Bienvenida ── }}
<div class="d-flex align-items-center justify-content-between mb-4 border-bottom pb-3">
  <div>
    <h1 class="fw-bold mb-0">
      <i class="bi bi-bicycle text-warning me-2"></i>Panel de repartidor
    </h1>
    <p class="text-muted mb-0 small">Hola, {{session.userName}} · AppCenar</p>
  </div>
  <a href="/auth/logout" class="btn btn-outline-danger btn-sm">
    <i class="bi bi-box-arrow-right me-1"></i>Cerrar sesión
  </a>
</div>

{{> alerts}}

{{! ── Opciones del repartidor ── }}
<div class="row g-4">

  <div class="col-12 col-md-4">
    <div class="card h-100 border-0 shadow-sm text-center p-3">
      <div class="card-body">
        <i class="bi bi-box-seam display-4 text-warning mb-3 d-block"></i>
        <h5 class="fw-semibold">Pedidos disponibles</h5>
        <p class="text-muted small">Revisa los pedidos listos para retirar</p>
        <a href="/delivery/orders" class="btn btn-warning btn-sm fw-semibold mt-2">Ver pedidos</a>
      </div>
    </div>
  </div>

  <div class="col-12 col-md-4">
    <div class="card h-100 border-0 shadow-sm text-center p-3">
      <div class="card-body">
        <i class="bi bi-map display-4 text-warning mb-3 d-block"></i>
        <h5 class="fw-semibold">Pedido en curso</h5>
        <p class="text-muted small">Sigue el estado de tu entrega activa</p>
        <a href="/delivery/orders" class="btn btn-warning btn-sm fw-semibold mt-2">Ver entrega</a>
      </div>
    </div>
  </div>

  <div class="col-12 col-md-4">
    <div class="card h-100 border-0 shadow-sm text-center p-3">
      <div class="card-body">
        <i class="bi bi-check2-all display-4 text-warning mb-3 d-block"></i>
        <h5 class="fw-semibold">Historial de entregas</h5>
        <p class="text-muted small">Consulta todas tus entregas anteriores</p>
        <a href="/delivery/orders" class="btn btn-warning btn-sm fw-semibold mt-2">Ver historial</a>
      </div>
    </div>
  </div>

  <div class="col-12 col-md-4">
    <div class="card h-100 border-0 shadow-sm text-center p-3">
      <div class="card-body">
        <i class="bi bi-toggle-on display-4 text-warning mb-3 d-block"></i>
        <h5 class="fw-semibold">Disponibilidad</h5>
        <p class="text-muted small">Activa o desactiva tu disponibilidad para recibir pedidos</p>
        <form action="/delivery/availability/toggle" method="POST" class="mt-2">
          <button type="submit" class="btn btn-warning btn-sm fw-semibold">Cambiar estado</button>
        </form>
      </div>
    </div>
  </div>

  <div class="col-12 col-md-4">
    <div class="card h-100 border-0 shadow-sm text-center p-3">
      <div class="card-body">
        <i class="bi bi-person-gear display-4 text-warning mb-3 d-block"></i>
        <h5 class="fw-semibold">Mi perfil</h5>
        <p class="text-muted small">Edita tus datos personales</p>
        <a href="/delivery/profile" class="btn btn-warning btn-sm fw-semibold mt-2">Ver perfil</a>
      </div>
    </div>
  </div>

</div>
